      "args": [
        "-e",
        "process.stdin.on('data', d => process.stdout.write('A> ' + d))"
      ]
    },
    {
      "id": "echo-b",
      "aliases": ["eb"],
      "name": "Echo B",
      "command": "node",
      "mode": "turn",
      "role": "reviewer",
      "bracketedPaste": false,
      "args": [
        "-e",
        "process.stdin.on('data', d => process.stdout.write('B> ' + d))"
      ]
    }
  ]
}
